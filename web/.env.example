# ── Required ──────────────────────────────────────────────────────────────────

# URL of the Render-hosted FastAPI backend (server-side only, not exposed to browser)
API_URL=https://your-service.onrender.com

# Password to log into the web app (must match APP_PASSWORD on the API)
APP_PASSWORD=

# Random secret for signing session cookies — generate with: openssl rand -hex 32
AUTH_SECRET=
