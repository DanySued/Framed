# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Render provides this automatically via render.yaml)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Pexels API key — get from pexels.com/api (can also be set via the Settings page in the app)
PEXELS_API_KEY=

# Password to log into the app
APP_PASSWORD=

# ── Web-only (not needed if you're only using the mobile app) ─────────────────

# Random secret for signing login session cookies (web frontend)
AUTH_SECRET=

# Comma-separated list of allowed frontend origins (e.g. your Vercel URL)
ALLOWED_ORIGINS=http://localhost:3000

# ── Optional (have defaults) ──────────────────────────────────────────────────

# Where to store generated videos and uploaded audio (mounted Render disk)
MEDIA_DIR=/media

# Where to store the SQLite file (local dev only) and .env.keys (persistent key saves)
DATA_DIR=/data
