# ── Supabase (get from: supabase.com → Project Settings → API) ─────────────────
EXPO_PUBLIC_SUPABASE_URL=https://hhnxglovthqxansfafeo.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service key — server-only (API routes, worker). Never expose to the client bundle.
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── API server ─────────────────────────────────────────────────────────────────
# Set after EAS Hosting deploy (Phase 7). In dev, API routes run on localhost.
EXPO_PUBLIC_API_URL=

# ── Pexels (get from: pexels.com/api) ─────────────────────────────────────────
PEXELS_API_KEY=your-pexels-api-key-here

# ── Sentry (get from: sentry.io → Project Settings → Client Keys) ─────────────
EXPO_PUBLIC_SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/123456
